{
  "name": "connectme-backend",
  "version": "1.0.0",
  "description": "ConnectMe Backend API Server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node init-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:alter": "node scripts/migrate.js --alter",
    "db:migrate:force": "node scripts/migrate.js --force",
    "db:seed:mock": "node scripts/seed-mock-data.js --reset",
    "db:seed:mock:append": "node scripts/seed-mock-data.js --append",
    "db:reset:mock": "npm run db:migrate:force && npm run db:seed:mock:append",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll"
  },
  "keywords": ["social-media", "instagram", "chat", "webrtc"],
  "author": "ConnectMe Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.2",
    "aws-sdk": "^2.1450.0",
    "cloudinary": "^1.40.0",
    "firebase-admin": "^11.11.0",
    "twilio": "^4.16.0",
    "nodemailer": "^6.9.5",
    "@sendgrid/mail": "^7.7.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0",
    "joi": "^17.10.1",
    "sharp": "^0.32.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "uuid": "^9.0.0",
    "moment": "^2.29.4",
    "socket.io-redis": "^6.1.1",
    "redis": "^4.6.8",
    "agenda": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "supertest": "^6.3.3",
    "eslint": "^8.48.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
