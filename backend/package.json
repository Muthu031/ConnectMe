{
  "name": "connectme-backend",
  "version": "1.0.0",
  "description": "ConnectMe Backend API Server",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "init-db": "ts-node init-db.ts",
    "db:migrate": "ts-node scripts/migrate.ts",
    "db:migrate:alter": "ts-node scripts/migrate.ts --alter",
    "db:migrate:force": "ts-node scripts/migrate.ts --force",
    "db:seed:mock": "ts-node scripts/seed-mock-data.ts --reset",
    "db:seed:mock:append": "ts-node scripts/seed-mock-data.ts --append",
    "db:reset:mock": "npm run db:migrate:force && npm run db:seed:mock:append",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll"
  },
  "keywords": [
    "social-media",
    "instagram",
    "chat",
    "webrtc"
  ],
  "author": "ConnectMe Team",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^7.7.0",
    "agenda": "^5.0.0",
    "aws-sdk": "^2.1450.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.40.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^11.11.0",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.0.0",
    "joi": "^17.10.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.5",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.8",
    "sequelize": "^6.35.2",
    "sharp": "^0.32.5",
    "socket.io": "^4.7.2",
    "socket.io-redis": "^6.1.1",
    "twilio": "^4.16.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "eslint": "^8.48.0",
    "jest": "^29.6.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
